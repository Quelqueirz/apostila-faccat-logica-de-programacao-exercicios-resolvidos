Algoritmo "CaixaEletronico"
// Disciplina  : Lógica de Programaçăo
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Simulador de Caixa Eletronico
// Autor(a)    : Raquel Alves de Queiroz
// Data atual  : 11/09/2025

Var
   // Seçăo de Declaraçőes das variáveis
   opcao01, opcao01_01:inteiro
   conta,agencia:inteiro
   resposta:caractere

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("------CAIXA ELETRÔNICO DOS BC------")
   escreval("")
   escreval("")
   escreval("SELECIONE UMA OPÇĂO:")
   escreval("")
   escreval("1 - Consultar saldo: ")
   escreval("2 - Saque:")
   escreval("3 - Depósito:")
   escreval("4 - Transferęncia:")
   escreval("5 - Pagamentos:")
   escreval("6 - Extrato:")
   escreval("7 - Configuraçőes:")
   escreval("8 - Sair:")
   leia(opcao01)
   limpatela
   escolha opcao01
   caso 1
      escreval("Vocę escolheu a opçao:")
      escreval("")
      escreval("1- Consultar saldo: ")
      escreval("")
      escreval("SELECIONE UMA OPÇĂO:")
      escreval("1 - Exibir saldo da conta corrente:")
      escreval("2 - Exibir saldo da conta poupança:")
      leia(opcao01_01)
      limpatela
      escolha(opcao01_01)
      caso 1
         escreval("Vocę escolheu a opçao:")
         escreval("")
         escreval("1 - Exibir saldo da conta corrente:")
         escreval("")
         escreval("Digite o número da agęncia: ")
         leia(agencia)
         escreval("Digite o número da conta: ")
         leia(conta)
         escreval("O saldo da conta é:R$1000,00 ")
         escreval("")
         limpatela
         escreval("Deseja voltar ao menu inicial?")
         leia(resposta)
         se resposta="Sim" entao
            escreval("")
            escreval("SELECIONE UMA OPÇĂO:")
            escreval("")
            escreval("1 - Consultar saldo: ")
            escreval("2 - Saque:")
            escreval("3 - Depósito:")
            escreval("4 - Transferęncia:")
            escreval("5 - Pagamentos:")
            escreval("6 - Extrato:")
            escreval("7 - Configuraçőes:")
            escreval("8 - Sair:")
         senao
            escreval("Obrigado por usar nossos serviços")
         fimse
      outrocaso
         escreval("Vocę escolheu a opçao:")
         escreval("")
         escreval("2 - Exibir saldo da conta poupança:")
         escreval("")
         escreval("Digite o número da agęncia: ")
         leia(agencia)
         escreval("Digite o número da conta: ")
         leia(conta)
         escreval("O saldo da conta é:R$5000,00 ")
         escreval("")
         escreval("Deseja voltar ao menu inicial?")
         leia(resposta)
         limpatela
         se resposta="Sim" entao
            escreval("")
            escreval("SELECIONE UMA OPÇĂO:")
            escreval("")
            escreval("1 - Consultar saldo: ")
            escreval("2 - Saque:")
            escreval("3 - Depósito:")
            escreval("4 - Transferęncia:")
            escreval("5 - Pagamentos:")
            escreval("6 - Extrato:")
            escreval("7 - Configuraçőes:")
            escreval("8 - Sair:")
         senao
            escreval("Obrigado por usar nossos serviços")
         fimse
      fimescolha
   fimescolha
fimescolha
Fimalgoritmo